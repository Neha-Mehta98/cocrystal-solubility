# Use lower walls to prevent the crystal from dissolving
LOWER_WALLS ARG=l4b_THE_C2 AT=17.0 KAPPA=25 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l4b_THE_C2
LOWER_WALLS ARG=l4b_THE_O1 AT=17.0 KAPPA=25 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l4b_THE_O1
LOWER_WALLS ARG=l4b_ASP_C3 AT=17.0 KAPPA=25 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l4b_ASP_C3
LOWER_WALLS ARG=l4b_ASP_O2 AT=17.0 KAPPA=25 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l4b_ASP_O2
LOWER_WALLS ARG=l4a_THE_C2 AT=20.0 KAPPA=25 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l4a_THE_C2
LOWER_WALLS ARG=l4a_THE_O1 AT=20.0 KAPPA=25 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l4a_THE_O1
LOWER_WALLS ARG=l4a_ASP_C3 AT=20.0 KAPPA=25 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l4a_ASP_C3
LOWER_WALLS ARG=l4a_ASP_C7 AT=20.0 KAPPA=25 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l4a_ASP_C7
LOWER_WALLS ARG=l1a_THE AT=20.0 KAPPA=15 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l1a_THE
LOWER_WALLS ARG=l1a_ASP AT=20.0 KAPPA=15 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l1a_ASP

# Use upper wall to dissolve layer4B partially
UPPER_WALLS ARG=s_diss_THE AT=0.1 KAPPA=1000 EXP=2 EPS=1.0 OFFSET=0 LABEL=uwall_s_diss_THE
UPPER_WALLS ARG=s_diss_ASP AT=0.1 KAPPA=1000 EXP=2 EPS=1.0 OFFSET=0 LABEL=uwall_s_diss_ASP

# Use upper wall to prevent layer0 from growing
UPPER_WALLS ARG=s_gp_THE AT=0.5 KAPPA=15 EXP=2 EPS=1.0 OFFSET=0 LABEL=uwall_s_gp_THE
UPPER_WALLS ARG=s_gp_ASP AT=0.5 KAPPA=15 EXP=2 EPS=1.0 OFFSET=0 LABEL=uwall_s_gp_ASP

# Use position restraint to prevent to the COM of the crystal to prevent its drift
 COM ATOMS=842,863,884,905,947,968,989,1010,1031,1073,1094,1115,1136,1157,1178,1199,1220,1241,1283,1304,1325,1346,1367,1388,1409,1451,1472,1493,1514,1535,1556,1577,1598,1619,1640,1661,4205,4226,4247,4289,4310,4331,4352,4373,4394,4415,4457,4499,4520,4541,4562,4583,4604,4625,4646,4667,4688,4709,4730,4751,4772,4793,4814,4835,4856,4898,4919,4940,4961,5003,5024 LABEL=cc NOPBC
F: FIXEDATOM AT=1.873555,1.97601,8.228346  # initial position of COM calculated with plumed
DISTANCE ATOMS=cc,F LABEL=dc COMPONENTS NOPBC
RESTRAINT ARG=dc.x AT=0.0 KAPPA=1000000 LABEL=restra
RESTRAINT ARG=dc.y AT=0.0 KAPPA=1000000 LABEL=restrb
RESTRAINT ARG=dc.z AT=0.0 KAPPA=1000000 LABEL=restrc




# Print value of the CV and bias to a file named COLVAR
PRINT STRIDE=500  ARG=* FILE=COLVAR   
