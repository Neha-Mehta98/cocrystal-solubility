#Restart simulation. This command will append results of new simulations to the same output files  e.g. COLVAR.
RESTART


# Biased THE molecules
GROUP ATOMS=2941,3025,3193,6721,6742,6763,6784,6805,6826,6847,6868,6889,6910  LABEL=theopylline_C1

# Biased ASP molecules
GROUP ATOMS=6578,6494,6389,6935,6956,6977,6998,7019,7040,7061,7082,7103,7124  LABEL=aspirin_C3


# Dissolve 4th row partially
ZROWX ...
