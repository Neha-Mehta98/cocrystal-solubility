#Restart simulation. This command will append results of new simulations to the same output files, e.g. COLVAR.
RESTART


# Biased THE molecules
GROUP ATOMS=3026,3194,6722,6743,6764,6785,6806,6827,6848,6869,6890,6911  LABEL=theophylline_C2    # C2 atoms of THE

# Biased ASP molecules
GROUP ATOMS=6578,6494,6389,6935,6956,6977,6998,7019,7040,7061,7082,7103,7124  LABEL=aspirin


# Dissolve 4th row partially
ZROWX ...
 LABEL=s_diss_THE
 CENTER=theophylline_C2
 ZETAL_X=-10.00
 ZETAU_X=10.00
 SIGMAL_X=1000
 SIGMAU_X=1000
 LB_Z=0.00
 UB_Z=6.00
 ZETAL_Z=1.10
 ZETAU_Z=2.40
 SIGMAL_Z=1000
 SIGMAU_Z=3
... ZROWX


# Dissolve 4th row partially
ZROWX ...
 LABEL=s_diss_ASP
 CENTER=aspirin
 ZETAL_X=-10.00
 ZETAU_X=10.00
 SIGMAL_X=1000
 SIGMAU_X=1000
 LB_Z=0.00
 UB_Z=6.00
 ZETAL_Z=1.10
 ZETAU_Z=2.40
 SIGMAL_Z=1000
 SIGMAU_Z=3
... ZROWX


# Prevent crystalline layer 4B THE molecules from dissolving
ZPYC1C2C5C7 ...
 LABEL=l4b_THE_C2
 CENTER=2942,2963,2984,3005,3047,3068,3089,3110,3131,3152,3173,3215,3236,3257,3278,3299,3320,3341      # C2 atom of THE
 ZETA_T=0.10
 SIGMA_T=150
 NU_X=5
 PHI_X1=-1.548654
 PHI_X2=-1.360752
 PHI_X3=-1.175096
 PHI_X4=-0.986259
 ETA_X=4
 NU_Y=1
 PHI_Y1=1.469954
 PHI_Y2=0.481988
 PHI_Y3=-0.506293
 PHI_Y4=-1.494377
 ETA_Y=130
 MU_Z1=1.548243
 MU_Z2=1.548243
 VAR_Z=0.107
... ZPYC1C2C5C7

ZPYC1C2C5C7 ...
 LABEL=l4b_THE_O1
 CENTER=2955,2976,2997,3018,3060,3081,3102,3123,3144,3165,3186,3228,3249,3270,3291,3312,3333,3354      # O1 atom of THE
