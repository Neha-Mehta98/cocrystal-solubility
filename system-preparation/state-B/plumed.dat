 MU_Z2=1.838577
 VAR_Z=0.107
... ZPYC1C2C5C7


# Prevent crystalline layer 4B ASP molecules from dissolving
ZPYC1C2C5C7 ...
 LABEL=l4b_ASP
 CENTER=6305,6326,6347,6368,6410,6431,6452,6473,6515,6536,6557,6599,6620,6641,6662,6683,6704
 ZETA_T=0.10
 SIGMA_T=150
 NU_X=5
 PHI_X1=-1.399300
 PHI_X2=-1.590430
 PHI_X3=-1.023707
 PHI_X4=-0.469069
