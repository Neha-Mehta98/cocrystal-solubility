#Restart simulation. This command will append results of new simulations to the same output files, e.g. COLVAR.
RESTART


# Biased THE molecules
GROUP ATOMS=2984,3026,3110,3152,3194,3236,3341  LABEL=theophylline_C2    # C2 atoms of THE


# Biased ASP molecules
GROUP ATOMS=6389,6410,6473,6494,6557,6578,6683,6704  LABEL=aspirin_C3    # C3 atoms of ASP
GROUP ATOMS=6394,6415,6478,6499,6562,6583,6688,6709  LABEL=aspirin_C7    # C7 atoms of ASP
GROUP ATOMS=6398,6419,6482,6503,6566,6587,6692,6713  LABEL=aspirin_O2    # O2 atoms of ASP
GROUP ATOMS=6404,6425,6488,6509,6572,6593,6698,6719  LABEL=aspirin_C9    # C9 atoms of ASP


# Define groups for TNshell and biased CV
GROUP ATOMS=theophylline_C2,aspirin_C3,6721-25806:3 LABEL=all_THEcase
GROUP ATOMS=aspirin_C3,theophylline_C2,6721-25806:3 LABEL=all_ASPcase
GROUP ATOMS=6721-25806:3  LABEL=water


# CmuMD settings THE case 
TNSHELL ...
 LABEL=n_nr_THE
 GROUP=all_THEcase
 NSV=1
 SOLUTE=7
 NST=1
 DF=0.60
 DCR=0.16
 CRSIZE=0.42
 WF=0.02
 WOUT=0.003
 WIN=0.003
 NINT=1.0
 NZ=120
 ASYMM=1
... TNSHELL


# CmuMD settings ASP case
TNSHELL ...
 LABEL=n_nr_ASP
 GROUP=all_ASPcase
 NSV=1
 SOLUTE=8
 NST=1
 DF=0.60
 DCR=0.16
 CRSIZE=0.42
 WF=0.02
 WOUT=0.003
 WIN=0.003
 NINT=1.0
 NZ=120
 ASYMM=1
... TNSHELL


# RESTRAINING THE SOLUTE/SOLVENT CR DENSITY:
RESTRAINT ARG=n_nr_THE AT=0.03 KAPPA=100000.0 LABEL=napsr_THE   # THE density restraint
RESTRAINT ARG=n_nr_ASP AT=0.03 KAPPA=100000.0 LABEL=napsr_ASP   # ASP density restraint


# Prevent crystalline layer 4B THE molecules from dissolving
ZPYC1C2C5C7 ...
 LABEL=l4b_THE_C2
 CENTER=2942,2963,3005,3047,3068,3089,3131,3173,3215,3257,3278,3299,3320      # C2 atom of THE
 ZETA_T=0.10
 SIGMA_T=150
 NU_X=5
 PHI_X1=-1.548654
 PHI_X2=-1.360752
 PHI_X3=-1.175096
 PHI_X4=-0.986259
 ETA_X=4
 NU_Y=1
 PHI_Y1=1.469954
 PHI_Y2=0.481988
 PHI_Y3=-0.506293
 PHI_Y4=-1.494377
 ETA_Y=130
 MU_Z1=1.548243
 MU_Z2=1.548243
 VAR_Z=0.107
... ZPYC1C2C5C7

ZPYC1C2C5C7 ...
 LABEL=l4b_THE_O1
 CENTER=2955,2976,3018,3060,3081,3102,3144,3186,3228,3270,3291,3312,3333      # O1 atom of THE
 ZETA_T=0.10
 SIGMA_T=150
 NU_X=5
 PHI_X1=-1.432704
 PHI_X2=-1.619137
 PHI_X3=-1.059709
 PHI_X4=-1.245671
 ETA_X=4
 NU_Y=1
 PHI_Y1=-1.404153
 PHI_Y2=-0.416108
 PHI_Y3=0.572015
 PHI_Y4=1.559783
 ETA_Y=130
 MU_Z1=1.838577
 MU_Z2=1.838577
 VAR_Z=0.107
... ZPYC1C2C5C7



# Prevent THE growing at unfinished THE row
ZROWY ...
 LABEL=s_ur_THE
 CENTER=theophylline_C2
 ZETAL_Y=-1.92000
 ZETAU_Y=-0.80000
 SIGMAL_Y=150
 SIGMAU_Y=150
 LB_Z=0.00
 UB_Z=5.00
 ZETAL_Z=1.0000
 ZETAU_Z=2.4000
 SIGMAL_Z=1000
 SIGMAU_Z=150
... ZROWY

# Prevent ASP growing at unfinished THE row
ZROWY ...
 LABEL=s_ur_ASP
 CENTER=aspirin_C3
 ZETAL_Y=-1.92000
 ZETAU_Y=-1.52000
 SIGMAL_Y=150
 SIGMAU_Y=250
 LB_Z=0.00
 UB_Z=5.00
 ZETAL_Z=1.2000
 ZETAU_Z=2.4000
 SIGMAL_Z=1000
 SIGMAU_Z=150
... ZROWY


# Prevent THE growing at adjacent THE rows
ZROWY ...
 LABEL=s_ar_THE
 CENTER=theophylline_C2
 ZETAL_Y=0.10000
 ZETAU_Y=1.92000
 SIGMAL_Y=150
 SIGMAU_Y=150
 LB_Z=0.00
 UB_Z=5.00
 ZETAL_Z=1.0000
 ZETAU_Z=2.4000
 SIGMAL_Z=1000
 SIGMAU_Z=150
... ZROWY

# Prevent ASP growing at adjacent THE rows
ZROWY ...
 LABEL=s_ar_ASP
 CENTER=aspirin_C3
 ZETAL_Y=0.10000
 ZETAU_Y=1.92000
 SIGMAL_Y=150
 SIGMAU_Y=250
 LB_Z=0.00
 UB_Z=5.00
 ZETAL_Z=1.2000
 ZETAU_Z=2.4000
 SIGMAL_Z=1000
 SIGMAU_Z=150
... ZROWY



# Prevent crystalline layer 4B ASP molecules from dissolving
ZPYC1C2C5C7 ...
 LABEL=l4b_ASP
 CENTER=6305,6326,6347,6368,6431,6452,6515,6536,6599,6620,6641,6662
 ZETA_T=0.15
 SIGMA_T=150
 NU_X=5
 PHI_X1=-1.399300
 PHI_X2=-1.590430
 PHI_X3=-1.023707
 PHI_X4=-0.469069
 ETA_X=4
 NU_Y=1
 PHI_Y1=1.847109
 PHI_Y2=-1.115532
 PHI_Y3=-0.126709
 PHI_Y4=0.862018
 ETA_Y=130
 MU_Z1=2.116896
 MU_Z2=2.116896
 VAR_Z=0.107
... ZPYC1C2C5C7

# Prevent ASP opposite kink site from unfinished row (layer 4B) from growing
ZSPHERE ...
 LABEL=s_ur_ASP314
 CENTER=aspirin_C3
 X=0.281600
 Y=0.877348
 Z=2.113869
 D_MIN=0.40
 D_MAX=0.60
... ZSPHERE

# Prevent ASP adjacent adsorption site of kink site from unfinished row (layer 4B) from growing
ZSPHERE ...
 LABEL=s_ur_ASP310
 CENTER=aspirin_C3
 X=1.040837
 Y=0.853834
 Z=2.116309
 D_MIN=0.10
 D_MAX=0.20
... ZSPHERE


# Prevent crystalline layer 4A THE molecules from dissolving
ZPYC1C2C5C7 ...
 LABEL=l4a_THE_C2
