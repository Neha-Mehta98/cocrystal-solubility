 PHI_Y3=0.123619
 PHI_Y4=-0.864702
 ETA_Y=130
 MU_Z1=1.892445
 MU_Z2=1.892445
 VAR_Z=0.107
... ZPYC1C2C5C7

ZPYC1C2C5C7 ...
 LABEL=l4a_THE_O1
 CENTER=2535-2940:21
 ZETA_T=0.10
 SIGMA_T=150
 NU_X=5
 PHI_X1=-1.511857
 PHI_X2=-1.327104
 PHI_X3=-1.138893
 PHI_X4=-0.960021
 ETA_X=4
 NU_Y=1
 PHI_Y1=0.035963
 PHI_Y2=-0.952753
 PHI_Y3=2.011341
 PHI_Y4=1.023336
 ETA_Y=130
 MU_Z1=1.598597
 MU_Z2=1.598597
 VAR_Z=0.107
... ZPYC1C2C5C7


# Prevent crystalline layer 4A ASP molecules from dissolving
ZPYC1C2C5C7 ...
 LABEL=l4a_ASP
 CENTER=5885-6300:21
 ZETA_T=0.10
 SIGMA_T=150
 NU_X=5
 PHI_X1=-1.169623887
 PHI_X2=-1.357875846
 PHI_X3=-1.546272105
