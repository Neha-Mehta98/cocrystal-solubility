#Restart simulation. This command will append results of new simulations to the same output files, e.g. COLVAR.
RESTART


# Biased THE molecules
GROUP ATOMS=2942,3026,3194,6722,6743,6764,6785,6806,6827,6848,6869,6890,6911  LABEL=theophylline_C2    # C2 atoms of THE
GROUP ATOMS=2946,3030,3198,6726,6747,6768,6789,6810,6831,6852,6873,6894,6915  LABEL=theophylline_C3    # C3 atoms of THE
GROUP ATOMS=2955,3039,3207,6735,6756,6777,6798,6819,6840,6861,6882,6903,6924  LABEL=theophylline_O1    # O1 atoms of THE
GROUP ATOMS=2956,3040,3208,6736,6757,6778,6799,6820,6841,6862,6883,6904,6925  LABEL=theophylline_O2    # O2 atoms of THE


# Biased ASP molecules
GROUP ATOMS=6578,6494,6389,6935,6956,6977,6998,7019,7040,7061,7082,7103,7124  LABEL=aspirin_C3

# Wall THE molecules
GROUP ATOMS=theophylline_C2,theophylline_O1  LABEL=theophylline


# Define groups for TNshell and biased CV
GROUP ATOMS=theophylline_C2,7141-25998:3 LABEL=all_THEcase
GROUP ATOMS=aspirin_C3,7141-25998:3 LABEL=all_ASPcase
GROUP ATOMS=7141-25998:3  LABEL=water


# CmuMD settings THE case 
TNSHELL ...
 LABEL=n_nr_THE
 GROUP=all_THEcase
 NSV=1
 SOLUTE=13
 NST=1
 DF=0.60
 DCR=0.16
 CRSIZE=0.42
 WF=0.02
 WOUT=0.003
 WIN=0.003
 NINT=1.0
 NZ=120
 ASYMM=1
... TNSHELL


# CmuMD settings ASP case
TNSHELL ...
 LABEL=n_nr_ASP
 GROUP=all_ASPcase
 NSV=1
 SOLUTE=13	
 NST=1
 DF=0.60
 DCR=0.16
 CRSIZE=0.42
 WF=0.02
 WOUT=0.003
 WIN=0.003
 NINT=1.0
 NZ=120
 ASYMM=1
... TNSHELL


# RESTRAINING THE SOLUTE/SOLVENT CR DENSITY:
RESTRAINT ARG=n_nr_THE AT=0.06 KAPPA=150000.0 LABEL=napsr_THE   # THE density restraint
RESTRAINT ARG=n_nr_ASP AT=0.06 KAPPA=150000.0 LABEL=napsr_ASP   # ASP density restraint


# Prevent ASP from growing at the kink site
ZROWX ...
 LABEL=s_ASP_C3
 CENTER=aspirin_C3
 ZETAL_X=-10.00
 ZETAU_X=10.00
 SIGMAL_X=1000
 SIGMAU_X=1000
 LB_Z=0.00
 UB_Z=6.00
 ZETAL_Z=1.10
 ZETAU_Z=2.24
 SIGMAL_Z=1000
 SIGMAU_Z=150
... ZROWX


# Prevent adjacent adsorption site of kink site from unfinished row (layer 4B) from growing
ZSPHERE ...
 LABEL=s_153THE
 CENTER=theophylline
 X=0.137036
 Y=0.482621
 Z=1.547445
 D_MIN=0.15
 D_MAX=0.52
... ZSPHERE


# Prevent adjacent adsorption site of kink site from unfinished row (layer 4B) from growing
ZSPHERE ...
 LABEL=s_145THE
 CENTER=theophylline
 X=0.885744
 Y=0.482186
 Z=1.546566
 D_MIN=0.05
 D_MAX=0.20
... ZSPHERE


# Prevent THE growth at THE layer 4A row 1
ZROWY ...
 LABEL=s_lr_THE
 CENTER=theophylline
 ZETAL_Y=-1.97000
 ZETAU_Y=-1.71000
 SIGMAL_Y=150
 SIGMAU_Y=150
 LB_Z=0.00
 UB_Z=5.00
 ZETAL_Z=1.1000
 ZETAU_Z=2.0500
 SIGMAL_Z=1000
 SIGMAU_Z=150
... ZROWY



