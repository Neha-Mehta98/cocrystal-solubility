... ZSPHERE


# Use lower walls to prevent the crystal from dissolving
LOWER_WALLS ARG=l4b_THE_C2 AT=17.0 KAPPA=40 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l4b_THE_C2
LOWER_WALLS ARG=l4b_THE_O1 AT=17.0 KAPPA=40 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l4b_THE_O1
LOWER_WALLS ARG=l4b_ASP_C3 AT=17.0 KAPPA=40 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l4b_ASP_C3
LOWER_WALLS ARG=l4b_ASP_O2 AT=17.0 KAPPA=40 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l4b_ASP_O2
LOWER_WALLS ARG=l4a_THE_C2 AT=20.0 KAPPA=40 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l4a_THE_C2
LOWER_WALLS ARG=l4a_THE_O1 AT=20.0 KAPPA=40 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l4a_THE_O1
LOWER_WALLS ARG=l4a_ASP_C3 AT=20.0 KAPPA=40 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l4a_ASP_C3
LOWER_WALLS ARG=l4a_ASP_O2 AT=20.0 KAPPA=40 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l4a_ASP_O2
LOWER_WALLS ARG=l1a_THE AT=20.0 KAPPA=15 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l1a_THE
LOWER_WALLS ARG=l1a_ASP AT=20.0 KAPPA=15 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_l1a_ASP


## Use upper wall to prevent undesired growth of THE and ASP
UPPER_WALLS ARG=s_ASP_C3 AT=0.0 KAPPA=300 EXP=2 EPS=1.0 OFFSET=0 LABEL=uwall_s_ASP_C3
UPPER_WALLS ARG=s_153THE AT=0.0 KAPPA=300 EXP=2 EPS=1.0 OFFSET=0 LABEL=uwall_s_153THE
UPPER_WALLS ARG=s_145THE AT=0.0 KAPPA=300 EXP=2 EPS=1.0 OFFSET=0 LABEL=uwall_s_145THE
UPPER_WALLS ARG=s_lr_THE AT=0.0 KAPPA=300 EXP=2 EPS=1.0 OFFSET=0 LABEL=uwall_s_lr_THE
#UPPER_WALLS ARG=s_ur_THE AT=0.0 KAPPA=300 EXP=2 EPS=1.0 OFFSET=0 LABEL=uwall_s_ur_THE

# Use upper wall to prevent layer0 from growing
UPPER_WALLS ARG=s_gp_THE AT=0.0 KAPPA=150 EXP=2 EPS=1.0 OFFSET=0 LABEL=uwall_s_gp_THE
#UPPER_WALLS ARG=s_gp_ASP AT=0.0 KAPPA=150 EXP=2 EPS=1.0 OFFSET=0 LABEL=uwall_s_gp_ASP


#Use lower walls to prevent dislogement of molecules
LOWER_WALLS ARG=s_140THE AT=1.0 KAPPA=300 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_s_140THE
LOWER_WALLS ARG=s_125THE AT=1.0 KAPPA=300 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_s_125THE
LOWER_WALLS ARG=s_133THE AT=1.0 KAPPA=300 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_s_133THE
LOWER_WALLS ARG=s_295ASP AT=1.0 KAPPA=300 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_s_295ASP
LOWER_WALLS ARG=s_282ASP AT=1.0 KAPPA=300 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_s_282ASP
LOWER_WALLS ARG=s_292ASP AT=1.0 KAPPA=300 EXP=2 EPS=1.0 OFFSET=0 LABEL=lwall_s_292ASP


# Use position restraint to prevent to the COM of the crystal to prevent its drift
COM ATOMS=842,863,884,905,947,968,989,1010,1031,1073,1094,1115,1136,1157,1178,1199,1220,1241,1283,1304,1325,1346,1367,1388,1409,1451,1472,1493,1514,1535,1556,1577,1598,1619,1640,1661,4205,4226,4247,4289,4310,4331,4352,4373,4394,4415,4457,4499,4520,4541,4562,4583,4604,4625,4646,4667,4688,4709,4730,4751,4772,4793,4814,4835,4856,4898,4919,4940,4961,5003,5024 LABEL=cc NOPBC
F: FIXEDATOM AT=1.873555,1.97601,8.228346  # initial position of COM calculated with plumed
DISTANCE ATOMS=cc,F LABEL=dc COMPONENTS NOPBC
RESTRAINT ARG=dc.x AT=0.0 KAPPA=1000000 LABEL=restra
RESTRAINT ARG=dc.y AT=0.0 KAPPA=1000000 LABEL=restrb
RESTRAINT ARG=dc.z AT=0.0 KAPPA=1000000 LABEL=restrc



# Biased CV: THE part C2
ZSPHEREG2 ...
 LABEL=sw_C2
 CENTER=theophylline_C2
 X=1.636176
 Y=0.482265
 Z=1.546917
 SIGMA=0.20
 D_MAX=12.0
... ZSPHEREG2

# Biased CV: THE part C3
ZSPHEREG2 ...
 LABEL=sw_C3
 CENTER=theophylline_C3
 X=1.437955
 Y=0.336791
 Z=1.900719
 SIGMA=0.20
 D_MAX=12.0
... ZSPHEREG2

# Biased CV: THE part O1
ZSPHEREG2 ...
 LABEL=sw_O1
 CENTER=theophylline_O1
 X=1.938605
 Y=0.573122
 Z=1.837415
 SIGMA=0.20
 D_MAX=12.0
... ZSPHEREG2

# Biased CV: THE part O2
ZSPHEREG2 ...
 LABEL=sw_O2
 CENTER=theophylline_O2
 X=1.617628
 Y=0.375244
 Z=2.102063
 SIGMA=0.20
 D_MAX=12.0
... ZSPHEREG2

# Biased CV: H2O part
ZSPHEREG2 ...
 LABEL=se_C2
 CENTER=water
 X=1.636176
 Y=0.482265
 Z=1.546917
 SIGMA=0.10
 D_MAX=1.0
... ZSPHEREG2

# Improve performance by adjusting biased CVs
sws_C2: MATHEVAL ARG=sw_C2 FUNC=x^0.2+x^3 PERIODIC=NO
sws_O1: MATHEVAL ARG=sw_O1 FUNC=x^0.2+x^3 PERIODIC=NO
sws_O2: MATHEVAL ARG=sw_O2 FUNC=x^0.2+x^3 PERIODIC=NO
sws_C3: MATHEVAL ARG=sw_C3 FUNC=x^0.2+x^3 PERIODIC=NO
ses_C2: MATHEVAL ARG=se_C2 FUNC=x^0.3 PERIODIC=NO

# Add solute- and solvent diffusion CVs to the biased CV bcv
COMBINE LABEL=bcv ARG=sws_C2,sws_C3,sws_O1,sws_O2,ses_C2 COEFFICIENTS=0.50,0.20,0.25,0.20,-0.15 PERIODIC=NO


# Construct a bias potential using metadynamics
METAD ...
 LABEL=metad
 ARG=bcv
 PACE=500
 HEIGHT=0.2
 SIGMA=0.09
 FILE=HILLS
 BIASFACTOR=10.0
 TEMP=300.0
 GRID_MIN=-1.2
 GRID_MAX=3.3
 GRID_BIN=150
 CALC_RCT
... METAD


# Walls
LOWER_WALLS ARG=sws_C2 AT=0.01 KAPPA=25 EXP=2 EPS=0.2 OFFSET=0 LABEL=lwall_sws_C2
UPPER_WALLS ARG=sws_C2 AT=2.01 KAPPA=75 EXP=2 EPS=0.2 OFFSET=0 LABEL=uwall_sws_C2
LOWER_WALLS ARG=sws_O1 AT=0.01 KAPPA=25 EXP=2 EPS=0.2 OFFSET=0 LABEL=lwall_sws_O1
UPPER_WALLS ARG=sws_O1 AT=2.01 KAPPA=75 EXP=2 EPS=0.2 OFFSET=0 LABEL=uwall_sws_O1
LOWER_WALLS ARG=sws_O2 AT=0.01 KAPPA=25 EXP=2 EPS=0.2 OFFSET=0 LABEL=lwall_sws_O2
UPPER_WALLS ARG=sws_O2 AT=2.01 KAPPA=75 EXP=2 EPS=0.2 OFFSET=0 LABEL=uwall_sws_O2
LOWER_WALLS ARG=sws_C3 AT=0.01 KAPPA=25 EXP=2 EPS=0.2 OFFSET=0 LABEL=lwall_sws_C3
UPPER_WALLS ARG=sws_C3 AT=2.01 KAPPA=75 EXP=2 EPS=0.2 OFFSET=0 LABEL=uwall_sws_C3
LOWER_WALLS ARG=ses_C2 AT=0.02 KAPPA=25 EXP=2 EPS=0.2 OFFSET=0 LABEL=lwall_ses_C2
UPPER_WALLS ARG=ses_C2 AT=1.01 KAPPA=50 EXP=2 EPS=0.2 OFFSET=0 LABEL=uwall_ses_C2


# Print value of the CV and bias to a file named COLVAR
PRINT STRIDE=500  ARG=* FILE=COLVAR   
